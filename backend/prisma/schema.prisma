// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  MEMBER
  LIBRARIAN
  ADMIN
}

enum LoanStatus {
  BORROWED
  RETURNED
  OVERDUE
  LOST
}

enum HoldStatus {
  ACTIVE
  APPROVED
  READY
  FULFILLED
  CANCELLED
  EXPIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  BORROW
  RETURN
  APPROVE
  REJECT
}

/** Physical copy on the shelf; library barcode is not the ISBN. */
enum CopyStatus {
  AVAILABLE
  ON_LOAN
  LOST
  DAMAGED
}

enum MessageType {
  DUE_REMINDER
  HOLD_READY
  SYSTEM
}

enum IncidentType {
  LOST
  DAMAGED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CLOSED
}

enum PaymentProvider {
  ALIPAY
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole    @default(MEMBER)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  loans        Loan[]
  ratings      Rating[]
  holds        Hold[]
  wishlists    Wishlist[]
  auditLogs    AuditLog[]
  messages     InAppMessage[]
  payments     Payment[]

  @@index([fullName])
}

model Book {
  id              String      @id @default(cuid())
  isbn            String      @unique
  /** Scannable catalog barcode (often ISBN EAN); distinct from copy-level libraryBarcode. */
  barcode         String?     @unique
  title           String
  author          String
  publisher       String?
  publishedYear   Int?
  category        String?
  description     String?
  language        String?
  shelfLocation   String?
  coverImageUrl   String?
  totalCopies     Int         @default(1)
  availableCopies Int         @default(1)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  loans           Loan[]
  ratings         Rating[]
  holds           Hold[]
  wishlists       Wishlist[]
  copies          BookCopy[]

  @@index([title])
  @@index([author])
  @@index([category])
  @@index([barcode])
}

model BookCopy {
  id             String             @id @default(cuid())
  bookId         String
  libraryBarcode String             @unique
  status         CopyStatus         @default(AVAILABLE)
  createdAt      DateTime           @default(now())
  book           Book               @relation(fields: [bookId], references: [id], onDelete: Cascade)
  loans          Loan[]
  incidents      BookCopyIncident[]

  @@index([bookId])
  @@index([bookId, status])
}

model BookCopyIncident {
  id           String       @id @default(cuid())
  bookCopyId   String
  bookId       String
  type         IncidentType
  notes        String?
  fineAmount   Float        @default(0)
  reportedById String?
  createdAt    DateTime     @default(now())
  bookCopy     BookCopy     @relation(fields: [bookCopyId], references: [id], onDelete: Cascade)

  @@index([bookId, createdAt])
  @@index([bookCopyId])
  @@index([type, createdAt])
}

model InAppMessage {
  id               String      @id @default(cuid())
  userId           String
  type             MessageType
  title            String
  body             String
  relatedEntityType String?
  relatedEntityId  String?
  readAt           DateTime?
  createdAt        DateTime    @default(now())
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([relatedEntityType, relatedEntityId, type])
}

model Loan {
  id          String     @id @default(cuid())
  userId      String
  bookId      String
  bookCopyId  String?
  borrowedAt  DateTime   @default(now())
  dueAt       DateTime
  returnedAt  DateTime?
  status      LoanStatus @default(BORROWED)
  renewCount  Int        @default(0)
  fineAmount  Float      @default(0)
  finePaid    Boolean    @default(false)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  book        Book       @relation(fields: [bookId], references: [id], onDelete: Restrict)
  bookCopy    BookCopy?  @relation(fields: [bookCopyId], references: [id], onDelete: SetNull)
  payments    Payment[]

  @@index([userId, status])
  @@index([bookId, status])
  @@index([dueAt])
  @@index([bookCopyId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  score     Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId, score])
}

model Hold {
  id           String     @id @default(cuid())
  userId       String
  bookId       String
  status       HoldStatus @default(ACTIVE)
  queuePosition Int?
  placedAt     DateTime   @default(now())
  expiresAt    DateTime?
  approvedAt   DateTime?
  readyAt      DateTime?
  fulfilledAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  book         Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, status, placedAt])
  @@index([userId, status])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  notes     String?
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, priority])
}

model Config {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id           String          @id @default(cuid())
  userId       String
  loanId       String?
  amount       Float
  provider     PaymentProvider @default(ALIPAY)
  status       PaymentStatus   @default(PENDING)
  outTradeNo   String          @unique
  tradeNo      String?
  subject      String?
  qrCode       String?
  paidAt       DateTime?
  notifyRaw    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  loan         Loan?           @relation(fields: [loanId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([loanId])
  @@index([status, createdAt])
  @@index([paidAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
