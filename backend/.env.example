# Copy to .env and adjust if needed

DATABASE_URL="file:./prisma/dev.db"

JWT_SECRET=change-me-in-production

PORT=3001



# --- Alipay sandbox (手机扫码支付) ---

# 1. 登录 https://open.alipay.com → 开发者中心 → 沙箱

# 2. 获取沙箱 APPID、支付宝公钥；用「支付宝开放平台密钥工具」生成应用私钥（建议 PKCS1）

# 3. 将下列三项填入 .env（私钥可用一行，\\n 表示换行）

# 4. 手机安装「支付宝沙箱版」APP，用沙箱买家账号登录后扫码付款

# 5. 本地开发无法接收异步通知时，前端会自动轮询查单；若需测试 notify，用 ngrok 暴露后端并设置 ALIPAY_NOTIFY_BASE



ALIPAY_MODE=sandbox

ALIPAY_APP_ID=

ALIPAY_PRIVATE_KEY=

ALIPAY_ALIPAY_PUBLIC_KEY=

# 新版沙箱网关（默认）

ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 密钥工具生成 PKCS8 时设为 PKCS8，否则默认 PKCS1

# ALIPAY_KEY_TYPE=PKCS1



# 异步通知公网地址（本地默认 http://localhost:3001，仅轮询查单时可不改）

ALIPAY_NOTIFY_BASE=http://localhost:3001

FRONTEND_BASE=http://localhost:5173



# 不配置上述密钥时，使用内置模拟支付页（ALIPAY_MODE=simulate 强制模拟）

